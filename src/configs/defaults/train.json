{
  "project": {
    "name": "ActionFlow",
    "output_dir": "outputs",
    "seed": 42
  },
  "runtime": {
    "device": "auto",
    "num_workers": 4,
    "mixed_precision": true,
    "log_level": "INFO"
  },
  "data": {
    "dataset_name": "ucf101",
    "dataset_root": "data/UCF101",
    "split": "split_1",
    "clip_length": 10,
    "frame_stride": 2,
    "resize_height": 224,
    "resize_width": 224,
    "class_names": [
      "running",
      "walking",
      "jumping",
      "falling"
    ],
    "cache_dir": "data/cache"
  },
  "flow": {
    "backend": "farneback",
    "representation": "stacked_flow",
    "precompute": true,
    "cache_dir": "data/cache/flow",
    "params": {
      "levels": 3,
      "winsize": 15,
      "iterations": 3
    }
  },
  "model": {
    "architecture": "resnet18_flow",
    "num_classes": 4,
    "input_channels": 20,
    "pretrained": false,
    "checkpoint": null
  },
  "training": {
    "batch_size": 8,
    "epochs": 20,
    "learning_rate": 0.001,
    "weight_decay": 0.0001
  },
  "evaluation": {
    "benchmark_batch_size": 1,
    "warmup_steps": 5,
    "timed_steps": 20,
    "measure_memory": true
  },
  "demo": {
    "host": "127.0.0.1",
    "port": 7860,
    "share": false,
    "title": "ActionFlow Demo",
    "enabled_backends": [
      "farneback",
      "lucas_kanade",
      "raft"
    ],
    "live_frame_interval_ms": 100
  }
}
